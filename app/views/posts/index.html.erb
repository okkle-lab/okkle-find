<% content_for :title, "Latest in AI — AI Finder" %>

<section class="results-head">
  <%= link_to "← home", root_path, class: "back-link" %>
  <h1 class="results-title">Latest in AI</h1>
  <p class="interpretation">Plain-English notes on new releases and what actually changed for everyday users.</p>
</section>

<% if @posts.any? %>
  <div class="posts-magazine">
    <% @posts.each_with_index do |post, i| %>
      <%= link_to post_path(post), class: "pmag-card#{' pmag-card-lead' if i.zero?}" do %>
        <span class="pmag-kicker">
          <span class="pmag-dot"></span>
          <% if post.published_at %><%= post.published_at.strftime("%-d %b %Y") %><% end %>
          <% if post.source_name.present? %><span class="pmag-source">via <%= post.source_name %></span><% end %>
        </span>
        <span class="pmag-title"><%= post.title %></span>
        <% if post.excerpt.present? %>
          <span class="pmag-excerpt"><%= truncate(post.excerpt, length: i.zero? ? 220 : 110) %></span>
        <% end %>
        <span class="pmag-read">Read <%= icon("external-link", size: 13) %></span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="interpretation">No posts yet — check back soon.</p>
<% end %>
