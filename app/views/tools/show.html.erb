<% content_for :title, "#{@tool.name} — AI Finder" %>

<article class="detail">
  <%= link_to "← back", root_path, class: "back-link" %>

  <header class="detail-head">
    <h1 class="detail-name"><%= @tool.name %></h1>
    <% if @tool.provider.present? %>
      <p class="detail-provider">by <%= @tool.provider %></p>
    <% end %>
    <% if @tool.categories.any? %>
      <p class="detail-cats">
        <% @tool.categories.ordered.each do |c| %>
          <%= link_to c.display_name, search_path(category: c.slug), class: "chip" %>
        <% end %>
      </p>
    <% end %>
  </header>

  <% if @tool.why_this_one.present? %>
    <p class="detail-why"><%= @tool.why_this_one %></p>
  <% end %>

  <ul class="detail-labels">
    <li class="label">💸 <%= @tool.display_price_label %></li>
    <li class="label">🔒 <%= @tool.display_privacy_label %></li>
    <li class="label">🛠️ <%= @tool.display_ease_label %></li>
  </ul>

  <%= render "scorecard", tool: @tool, priority_dimension: @priority_dimension %>

  <% if @tool.website_url.present? %>
    <p class="detail-visit"><%= link_to "Visit #{@tool.name} →", @tool.website_url, target: "_blank", rel: "noopener", class: "visit-btn",
          data: { controller: "event-logger", action: "click->event-logger#log",
                  "event-logger-type-value": "card_click", "event-logger-tool-value": @tool.id } %></p>
  <% end %>

  <% if @compare_candidates.results? %>
    <%= form_with url: compare_path, method: :get, class: "compare-add compare-with" do |f| %>
      <%= f.hidden_field :ids, value: @tool.id %>
      <%= f.hidden_field :from, value: @compare_candidates.from_param %>
      <%= f.label :add, "Compare with another result:", class: "compare-add-label" %>
      <%= f.select :add,
            options_from_collection_for_select(@compare_candidates.result_tools, :id, :name),
            { include_blank: "Choose a tool…" }, class: "compare-select" %>
      <%= f.submit "Compare", class: "compare-add-btn" %>
    <% end %>
  <% elsif @compare_candidates.catalogue? && @compare_candidates.catalogue_options? %>
    <%= form_with url: compare_path, method: :get, class: "compare-add compare-with" do |f| %>
      <%= f.hidden_field :ids, value: @tool.id %>
      <%= f.label :add, "Compare with:", class: "compare-add-label" %>
      <%= f.select :add,
            grouped_options_for_select([
              ["Similar tools", @compare_candidates.similar_tools.map { |t| [t.name, t.id] }],
              ["Other tools",   @compare_candidates.other_tools.map { |t| [t.name, t.id] }]
            ]),
            { include_blank: "Choose a tool…" }, class: "compare-select" %>
      <%= f.submit "Compare", class: "compare-add-btn" %>
    <% end %>
  <% end %>

  <footer class="detail-foot">
    <% if @tool.last_verified.present? %>
      <p class="last-checked">Last checked <%= @tool.last_verified.strftime("%-d %b %Y") %><%= ", pricing confidence: #{@tool.data_pricing_confidence}" if @tool.data_pricing_confidence.present? %>.</p>
    <% end %>
    <p class="disclaimer">Prices and privacy policies change — always confirm on the tool's own site before relying on this.</p>
  </footer>
</article>
