<% detailed = local_assigns.fetch(:detailed, false) %>
<% priority_dimension = local_assigns.fetch(:priority_dimension, nil) %>
<% pd_config = Rubric::DIMENSIONS[priority_dimension] %>
<% pd_fields = Rubric.fields_for(priority_dimension) %>
<%# Only explain the match when we actually have a score on that dimension —
    otherwise this tool is ranked on its overall, so show overall only. %>
<% pd_score = tool.dimension_score(priority_dimension) %>
<% pd_label = pd_config ? pd_config[:label].downcase : Rubric.label_for(priority_dimension) %>
<%# ease/privacy live only on the tool, so a per-model column only applies to
    dimensions the variants actually carry. %>
<% pd_variant_fields = pd_fields.select { |field| ModelVariant.column_names.include?(field.to_s) } %>
<% variants = tool.model_variants.ordered %>
<% product_matched_score = !detailed && !variants.any? && pd_score && pd_config && pd_config[:level] == :model %>

<section class="specs-block scorecard<%= " scorecard-prominent" if detailed %>">
  <div class="scorecard-head">
    <h2 class="specs-title">Our verdict</h2>
  </div>

  <%# Explains why the search surfaced this tool: the score it was ranked on
      (the user's intent) shown next to its overall verdict. %>
  <% if pd_score %>
    <div class="why-shown">
      <span class="why-shown-tag">Why you're seeing this</span>
      <span class="why-shown-text">Matched on <strong><%= pd_label %></strong></span>
      <span class="why-shown-stats">
        <span class="why-shown-stat">
          <%= colored_score(pd_score, css_class: "why-shown-num") %>
          <span class="why-shown-cap"><%= pd_label %></span>
        </span>
        <span class="why-shown-stat">
          <%= colored_score(tool.overall_verdict, css_class: "why-shown-num") %>
          <span class="why-shown-cap">overall</span>
        </span>
      </span>
    </div>
  <% end %>

  <% if product_matched_score %>
    <dl class="criteria-grid">
      <%# Product page from an intent search: surface just the matched score. %>
      <div class="criterion"><dt class="criterion-cap"><%= pd_label %></dt><dd><%= colored_score(pd_score) %></dd></div>
    </dl>
  <% end %>

  <div class="verdict-summary">
    <div class="verdict-model">
      <% if (v = tool.overall_verdict) %>
        <p class="verdict-headline"><%= colored_score(v, css_class: "verdict-num") %>/10</p>
      <% else %>
        <p class="verdict-headline verdict-none">Not yet rated</p>
      <% end %>
    </div>

    <div class="verdict-summary-grid">
      <div class="verdict-list">
        <h4>Best for:</h4>
        <ul>
          <% tool.verdict_best_for.each do |label| %>
            <li><%= label %></li>
          <% end %>
        </ul>
      </div>

      <div class="verdict-list">
        <h4>Not ideal for:</h4>
        <ul>
          <% tool.verdict_not_ideal_for.each do |label| %>
            <li><%= label %></li>
          <% end %>
        </ul>
      </div>

      <dl class="verdict-facts">
        <div>
          <dt>Models available:</dt>
          <dd><%= tool.verdict_models_available.presence || "—" %></dd>
        </div>
        <div>
          <dt>Free tier:</dt>
          <dd><%= tool.verdict_free_tier? ? "Yes" : "No" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <% if detailed && variants.any? %>
    <% grid_template = "1rem minmax(12rem, 1.45fr) repeat(#{variants.size}, minmax(0, 1fr))" %>
    <div class="score-category-list">
      <div class="score-category-summary score-category-header" style="grid-template-columns: <%= grid_template %>">
        <span>Criterion</span>
        <% variants.each do |variant| %>
          <span><%= variant.name %></span>
        <% end %>
      </div>

      <div class="score-category-summary score-overall-row" style="grid-template-columns: <%= grid_template %>">
        <span class="score-category-name">Overall</span>
        <% variants.each do |variant| %>
          <strong><%= colored_score(variant.verdict) %></strong>
        <% end %>
      </div>

      <% Rubric::OVERALL_CATEGORIES.each do |category, fields| %>
        <details class="score-category">
          <summary class="score-category-summary" style="grid-template-columns: <%= grid_template %>">
            <span class="score-category-name"><%= category %></span>
            <% variants.each do |variant| %>
              <%= colored_score(variant.category_score(fields, extra_scores: tool.rubric_field_values, category: category)) %>
            <% end %>
          </summary>
          <div class="scores-scroll score-category-details">
            <table class="models-table scores-table">
              <thead>
                <tr>
                  <th>Sub-score</th>
                  <% variants.each do |variant| %>
                    <th><%= variant.name %></th>
                  <% end %>
                </tr>
              </thead>
              <tbody>
                <% fields.each do |field| %>
                  <tr>
                    <th class="models-name" scope="row"><%= Rubric::SUBCATEGORY_FIELDS.key(field) || field.to_s.humanize %></th>
                    <% variants.each do |variant| %>
                      <td><%= colored_score(variant.category_score([field], extra_scores: tool.rubric_field_values, category: category)) %></td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      <% end %>
    </div>
  <% end %>

  <% unless detailed %>
    <p class="scorecard-review-link"><%= link_to "See full review →", review_tool_path(tool) %></p>
  <% end %>
</section>
