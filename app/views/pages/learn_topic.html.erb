<% content_for :title, "#{@topic[:title]} — AI Finder" %>

<article class="learn-article">
  <%= link_to "← all lessons", learn_path, class: "back-link" %>

  <header class="article-head">
    <span class="article-ic" style="color: <%= tool_monogram_color(@topic[:title]) %>"><%= icon(@topic[:icon], size: 30) %></span>
    <h1 class="page-title"><%= @topic[:title] %></h1>
    <p class="page-sub"><%= @topic[:summary] %></p>
  </header>

  <% @topic[:sections].each do |section| %>
    <section class="article-section">
      <h2 class="article-h2"><%= section[:heading] %></h2>
      <p class="article-body"><%= section[:body] %></p>
    </section>
  <% end %>

  <% if (key = @topic[:related_category]) %>
    <div class="article-cta-card">
      <div>
        <p class="article-cta-label">See it in the scores</p>
        <p class="article-cta-text">Which tools actually do this best? Browse the ranked leaderboard.</p>
      </div>
      <%= link_to "Open leaderboard →", leaderboard_path(key), class: "article-cta-btn" %>
    </div>
  <% end %>

  <section class="article-section">
    <h2 class="article-h2">Related articles</h2>
    <p class="article-related-empty">Hand-picked reading on this topic will appear here.</p>
  </section>
</article>
