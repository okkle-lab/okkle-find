<% content_for :title, "#{@topic[:title]} — AI Finder" %>

<article class="learn-article">
  <%= link_to "← all lessons", learn_path, class: "back-link" %>

  <header class="article-head">
    <span class="article-ic-wrap" style="background: <%= tool_monogram_color(@topic[:title]) %>18; color: <%= tool_monogram_color(@topic[:title]) %>"><%= icon(@topic[:icon], size: 26) %></span>
    <div class="article-head-text">
      <h1 class="page-title"><%= @topic[:title] %></h1>
      <p class="article-summary"><%= @topic[:summary] %></p>
    </div>
  </header>

  <% section_mods = %w[article-section--good article-section--caution article-section--tips] %>
  <% @topic[:sections].each_with_index do |section, i| %>
    <section class="article-section <%= section_mods[i] %>">
      <span class="article-section-num">0<%= i + 1 %></span>
      <h2 class="article-h2"><%= section[:heading] %></h2>
      <% if section[:body] %>
        <p class="article-body"><%= section[:body] %></p>
      <% end %>
      <% if section[:bullets]&.any? %>
        <ul class="article-bullets">
          <% section[:bullets].each do |bullet| %>
            <li><%= bullet %></li>
          <% end %>
        </ul>
      <% end %>
    </section>
  <% end %>

  <% if (key = @topic[:related_category]) %>
    <div class="article-cta-card">
      <div>
        <p class="article-cta-label">See it in the scores</p>
        <p class="article-cta-text">Which tools actually do this best? Browse the ranked leaderboard.</p>
      </div>
      <%= link_to "Open leaderboard →", leaderboard_path(key), class: "article-cta-btn" %>
    </div>
  <% end %>

  <section class="article-section article-section--related">
    <h2 class="article-h2">Related articles</h2>
    <p class="article-related-empty">Hand-picked reading on this topic will appear here.</p>
  </section>
</article>
