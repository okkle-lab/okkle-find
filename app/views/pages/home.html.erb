<% content_for :home_header, true %>

<section class="hero">
  <p class="hero-eyebrow">Curated · cross-judged · honest</p>
  <h1>What do you need AI to do?</h1>
  <p class="hero-sub">Describe it in plain English. We'll show the honest options — and the catch.</p>

  <%= form_with url: search_path, method: :get, class: "search-form" do |f| %>
    <%= f.search_field :q,
          placeholder: "e.g. transcribe my interviews privately",
          autofocus: true,
          autocomplete: "off",
          class: "search-input" %>
    <%= f.submit "Find tools", class: "search-button" %>
  <% end %>

  <ul class="hero-hints">
    <% ["write code", "free for coding", "most private", "transcribe meetings"].each do |hint| %>
      <li><%= link_to hint, search_path(q: hint), class: "hero-hint" %></li>
    <% end %>
  </ul>

  <p class="hero-stat">Independently testing <strong><%= @stats[:tools] %> tools</strong> and
    <strong><%= @stats[:models] %> models</strong> across <strong><%= @stats[:categories] %> categories</strong>. No sponsored rankings.</p>
</section>

<section class="home-section">
  <h2 class="panel-title">Browse by task</h2>
  <div class="tile-grid">
    <% @categories.each do |category| %>
      <%= link_to search_path(category: category.slug), class: "tile" do %>
        <span class="tile-icon" style="--icon-tint: <%= tool_monogram_color(category.display_name) %>"><%= icon(category.icon.presence || "sparkles", size: 22) %></span>
        <span class="tile-name"><%= category.display_name %></span>
        <span class="tile-sub"><%= category.subtitle %></span>
      <% end %>
    <% end %>
  </div>
</section>

<% if @top_rated.any? %>
  <section class="home-section">
    <div class="section-head">
      <h2 class="panel-title">Top rated overall</h2>
      <%= link_to "Browse all leaderboards →", leaderboards_path, class: "section-all" %>
    </div>
    <ol class="top-list">
      <% @top_rated.each_with_index do |(tool, score), i| %>
        <%= link_to tool_path(tool), class: "top-row" do %>
          <span class="top-rank"><%= i + 1 %></span>
          <%= tool_logo(tool, css_class: "top-logo") %>
          <span class="top-main">
            <span class="top-name"><%= tool.name %></span>
            <% if tool.provider.present? %><span class="top-prov">by <%= tool.provider %></span><% end %>
          </span>
          <span class="top-score" style="color: <%= score_color(score) %>"><%= score_number(score) %></span>
        <% end %>
      <% end %>
    </ol>
  </section>
<% end %>

<% if @recent_posts.any? %>
  <section class="home-section">
    <div class="section-head">
      <h2 class="panel-title">Latest in AI</h2>
      <%= link_to "All news →", posts_path, class: "section-all" %>
    </div>
    <div class="news-grid">
      <% @recent_posts.each_with_index do |post, i| %>
        <%= link_to post_path(post), class: "news-card#{' news-card-lead' if i.zero?}" do %>
          <span class="news-kicker">
            <span class="news-dot"></span>
            <% if post.published_at %><%= post.published_at.strftime("%-d %b %Y") %><% end %>
            <% if post.source_name.present? %><span class="news-source">via <%= post.source_name %></span><% end %>
          </span>
          <span class="news-title"><%= post.title %></span>
          <% if post.excerpt.present? %><span class="news-excerpt"><%= truncate(post.excerpt, length: i.zero? ? 160 : 90) %></span><% end %>
          <span class="news-readmore">Read <%= icon("external-link", size: 13) %></span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
