<% content_for :home_header, true %>

<section class="hero">
  <p class="hero-eyebrow">Curated · cross-judged · honest</p>
  <h1>What do you need AI to do?</h1>
  <p class="hero-sub">Describe it in plain English. We'll show the honest options — and the catch.</p>

  <%= form_with url: search_path, method: :get, class: "search-form", data: { header_search_sentinel: true } do |f| %>
    <%= f.search_field :q,
          placeholder: "e.g. transcribe my interviews privately",
          autofocus: true,
          autocomplete: "off",
          class: "search-input" %>
    <%= button_tag type: "submit", class: "search-button" do %>
      <%= icon("search", size: 18) %>
      <span>Find</span>
    <% end %>
  <% end %>

  <ul class="hero-hints">
    <% ["write code", "free for coding", "most private", "transcribe interviews"].each do |hint| %>
      <li><%= link_to hint, search_path(q: hint), class: "hero-hint" %></li>
    <% end %>
  </ul>

  <p class="hero-stat">Independently testing <strong><%= @stats[:tools] %> tools</strong> and
    <strong><%= @stats[:models] %> models</strong> across <strong><%= @stats[:categories] %> categories</strong>. No sponsored rankings.</p>
</section>

<section class="home-section home-section--browse">
  <h2 class="panel-title">Browse by task</h2>
  <% tile_chips = {
    "write-things"   => ["drafting", "summarisation", "editing"],
    "chat-assistant" => ["accuracy", "depth", "trustworthiness"],
    "code"           => ["speed", "accuracy", "debugging", "agentic"],
    "summarize"      => ["faithfulness", "format control", "length"],
    "research"       => ["citations", "hallucination resistance", "depth"],
    "audio-to-text"  => ["accuracy", "speaker detection", "privacy"],
    "translate"      => ["accuracy", "nuance", "speed"]
  } %>
  <div class="tile-grid">
    <% @categories.each do |category| %>
      <%= link_to search_path(category: category.slug), class: "tile" do %>
        <span class="tile-head">
          <span class="tile-name"><%= category.display_name.sub(/\A./, &:upcase) %></span>
        </span>
        <span class="tile-sub"><%= category.subtitle %></span>
        <% if (chips = tile_chips[category.slug]).present? %>
          <span class="tile-chips">
            <% chips.each do |chip| %>
              <span class="tile-chip"><%= chip %></span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<% if @top_rated.any? %>
  <section class="home-section">
    <div class="section-head">
      <h2 class="panel-title">Top rated overall</h2>
      <%= link_to "Browse all leaderboards →", leaderboards_path, class: "section-all" %>
    </div>
    <ol class="top-list">
      <% @top_rated.each_with_index do |(tool, score), i| %>
        <%= link_to tool_path(tool), class: "top-row" do %>
          <span class="top-rank"><%= i + 1 %></span>
          <%= tool_logo(tool, css_class: "top-logo") %>
          <span class="top-main">
            <span class="top-name"><%= tool.name %></span>
            <% if tool.provider.present? %><span class="top-prov">by <%= tool.provider %></span><% end %>
          </span>
          <span class="top-score" style="color: <%= score_color(score) %>"><%= score_number(score) %></span>
        <% end %>
      <% end %>
    </ol>
  </section>
<% end %>

<% if latest_in_ai_enabled? && @recent_posts.any? %>
  <section class="home-section">
    <div class="section-head">
      <h2 class="panel-title">Latest in AI</h2>
      <%= link_to "All news →", posts_path, class: "section-all" %>
    </div>
    <div class="news-grid">
      <% @recent_posts.each_with_index do |post, i| %>
        <% is_lead = i.zero? %>
        <%= link_to post_path(post), class: "news-card#{' news-card-lead' if is_lead}" do %>
          <span class="nc-img<%= ' nc-img--empty' unless post.image_url.present? %>"<%= post.image_url.blank? ? " style=\"background:#{post_type_color(post.post_type)}18\"".html_safe : "" %>>
            <% if post.image_url.present? %>
              <img src="<%= post.image_url %>" alt="" loading="lazy">
            <% end %>
          </span>
          <span class="nc-body">
            <span class="nc-kicker">
              <% if post.source_name.present? %><span class="nc-source"><%= post.source_name %></span><% end %>
              <% if post.published_at %><span class="nc-date"><%= post.published_at.strftime("%-d %b") %></span><% end %>
            </span>
            <span class="nc-title"><%= post.title %></span>
            <% if post.excerpt.present? %>
              <span class="nc-excerpt"><%= truncate(post.excerpt, length: is_lead ? 150 : 85) %></span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
