<% content_for :title, "Compare tools — AI Finder" %>

<section class="results-head">
  <h1 class="results-title">Comparing <%= pluralize(@tools.size, "tool") %></h1>
  <p class="interpretation">An honest side-by-side. Figures are our last-checked estimates — confirm on each tool's own site.</p>
</section>

<%
  free_to_try_summary = lambda do |tool|
    variants = tool.model_variants.ordered
    if variants.any?
      free_models = variants.select(&:free_to_try).map(&:name)
      free_models.any? ? "Yes: #{free_models.to_sentence}" : "No"
    else
      "—"
    end
  end

  score_rows = [
    ["Overall score", ->(t) { tag.strong(colored_score(t.overall_verdict)) }]
  ]
  Rubric.overall_categories.each do |label, fields|
    score_rows << [label, ->(t) { colored_score(t.comparison_category_score(fields)) }]
  end

  rows = score_rows + [
    ["Provider",                ->(t) { t.provider.presence || "—" }],
    ["Price",                   ->(t) { t.display_price_label }],
    ["API price",               ->(t) { t.price_summary }],
    ["Free to try",             ->(t) { free_to_try_summary.call(t) }],
    ["Free app for individuals",->(t) { t.consumer_free_app? ? "Yes" : "No" }],
    ["Free API tier",           ->(t) { t.api_free_tier? ? "Yes" : "No" }],
    ["Web search",              ->(t) { yes_no_or_unknown(t.has_web_search) }],
    ["Citations",               ->(t) { yes_no_or_unknown(t.shows_citations) }],
    ["File uploads",            ->(t) { yes_no_or_unknown(t.has_file_uploads) }],
    ["Image generation",        ->(t) { yes_no_or_unknown(t.has_image_generation) }],
    ["Image editing",           ->(t) { yes_no_or_unknown(t.has_image_editing) }],
    ["Coding agent",            ->(t) { yes_no_or_unknown(t.has_coding_agent) }],
    ["Code execution",          ->(t) { yes_no_or_unknown(t.has_code_execution) }],
    ["Repository access",       ->(t) { yes_no_or_unknown(t.has_repository_access) }],
    ["Deep research",           ->(t) { yes_no_or_unknown(t.has_deep_research) }],
    ["Live data access",        ->(t) { yes_no_or_unknown(t.has_live_data_access) }],
    ["Transcription",           ->(t) { yes_no_or_unknown(t.has_transcription) }],
    ["Meeting bot",             ->(t) { yes_no_or_unknown(t.has_meeting_bot) }],
    ["API",                     ->(t) { yes_no_or_unknown(t.has_api) }],
    ["Mobile app",              ->(t) { yes_no_or_unknown(t.has_mobile_app) }],
    ["Desktop app",             ->(t) { yes_no_or_unknown(t.has_desktop_app) }],
    ["Browser extension",       ->(t) { yes_no_or_unknown(t.has_browser_extension) }],
    ["Enterprise plan",         ->(t) { yes_no_or_unknown(t.has_enterprise_plan) }],
    ["SSO",                     ->(t) { yes_no_or_unknown(t.supports_sso) }],
    ["SOC2",                    ->(t) { yes_no_or_unknown(t.has_soc2) }],
    ["No training on user data",->(t) { yes_no_or_unknown(t.no_training_on_user_data) }],
    ["Runs on your computer",   ->(t) { t.runs_locally? ? "Yes" : "No" }],
    ["Data location",           ->(t) { fact_or_unknown(t.data_location) }],
    ["Trains on your data",     ->(t) { fact_or_unknown(t.trains_on_user_data) }],
    ["Retains your data",       ->(t) { fact_or_unknown(t.retains_user_data) }],
    ["Data retention",          ->(t) { t.data_retention.humanize }],
    ["Context window",          ->(t) { t.context_window ? "#{number_with_delimiter(t.context_window)} tokens" : "—" }],
    ["Last checked",            ->(t) { t.last_verified&.strftime("%-d %b %Y") || "—" }],
  ]
%>

<div class="compare-scroll">
  <table class="compare-table">
    <thead>
      <tr>
        <th class="compare-rowhead"></th>
        <% @tools.each do |tool| %>
          <th class="compare-colhead">
            <%= link_to tool.name, tool_path(tool) %>
            <% if @tools.size > 1 %>
              <%= link_to "remove", compare_path(ids: @ids_param, remove: tool.id, from: @from), class: "compare-remove" %>
            <% end %>
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% rows.each do |label, value| %>
        <tr>
          <th class="compare-rowhead" scope="row"><%= label %></th>
          <% @tools.each do |tool| %>
            <td><%= value.call(tool) %></td>
          <% end %>
        </tr>
      <% end %>
      <tr>
        <th class="compare-rowhead" scope="row"></th>
        <% @tools.each do |tool| %>
          <td>
            <% if tool.website_url.present? %>
              <%= link_to "Visit site →", tool.website_url, target: "_blank", rel: "noopener",
                    data: { controller: "event-logger", action: "click->event-logger#log",
                            "event-logger-type-value": "card_click", "event-logger-tool-value": tool.id } %>
            <% end %>
          </td>
        <% end %>
      </tr>
    </tbody>
  </table>
</div>

<% if @room && @addable&.any? %>
  <%= form_with url: compare_path, method: :get, class: "compare-add" do |f| %>
    <%= f.hidden_field :ids, value: @ids_param %>
    <%= f.hidden_field :from, value: @from %>
    <%= f.label :add, (@from.present? ? "Add another from your search:" : "Add another tool:"), class: "compare-add-label" %>
    <%= f.select :add, options_from_collection_for_select(@addable, :id, :name), { include_blank: "Choose…" }, class: "compare-select" %>
    <%= f.submit "Add", class: "compare-add-btn" %>
  <% end %>
  <% if @from.present? %>
    <p class="interpretation"><%= link_to "Compare against the whole catalogue instead", compare_path(ids: @ids_param) %>.</p>
  <% end %>
<% elsif @room && @from.present? %>
  <p class="interpretation">You're comparing all the tools from your search. <%= link_to "Add others from the catalogue", compare_path(ids: @ids_param) %>.</p>
<% elsif !@room %>
  <p class="interpretation">That's the max of <%= ComparisonsController::MAX_TOOLS %> tools side by side — remove one to swap.</p>
<% end %>
