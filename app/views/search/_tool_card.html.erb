<% search_context = local_assigns.fetch(:search_context, SearchContext.new) %>
<% dimension = search_context.priority_dimension %>
<% headline, caption = headline_score(tool, dimension) %>
<% criteria = dimension ? dimension_criteria(tool, dimension) : [] %>
<% has_scores = criteria.any? { |_label, score| score.present? } %>

<article class="card">
  <header class="card-head">
    <div class="card-headline">
      <%= tool_logo(tool, css_class: "card-logo") %>
      <div class="card-headline-text">
        <h3 class="card-name"><%= link_to tool.name, tool_path(tool, search_context.query_params) %></h3>
        <% if tool.provider.present? %><span class="card-provider">by <%= tool.provider %></span><% end %>
      </div>
    </div>
    <div class="score-pill<%= " score-pill-tbd" unless headline %>">
      <span class="score-pill-num"><%= headline ? score_number(headline) : "—" %></span>
      <span class="score-pill-cap"><%= caption %></span>
    </div>
  </header>

  <% if tool.why_this_one.present? %>
    <p class="card-why"><%= tool.why_this_one %></p>
  <% end %>

  <ul class="card-tags">
    <li class="tag tag-price"><%= tool.display_price_label %></li>
    <li class="tag tag-privacy"><%= tool.display_privacy_label %></li>
    <li class="tag tag-ease"><%= tool.display_ease_label %></li>
  </ul>

  <% if criteria.any? && has_scores %>
    <div class="card-bars">
      <% criteria.each do |label, score| %>
        <%= score_bar(label, score) %>
      <% end %>
    </div>
  <% elsif dimension %>
    <p class="card-tbd">
      <span class="card-tbd-icon" aria-hidden="true">◔</span>
      <%= Rubric.label_for(dimension) %> scores rolling out — testing in progress
    </p>
  <% end %>

  <% variants = tool.model_variants.sort_by { |v| [v.position, v.id] } %>
  <% if variants.any? %>
    <p class="card-models">
      <span class="card-models-label">Models:</span>
      <% variants.each do |variant| %>
        <span class="model-chip" title="<%= variant.chip_title %>"><%= variant.name %></span>
      <% end %>
    </p>
  <% end %>

  <footer class="card-foot">
    <%= link_to "See the full specs →", tool_path(tool, search_context.query_params), class: "card-link" %>
    <% if tool.website_url.present? %>
      <%= link_to "Visit site", tool.website_url, target: "_blank", rel: "noopener", class: "card-visit",
            data: { controller: "event-logger", action: "click->event-logger#log",
                    "event-logger-type-value": "card_click", "event-logger-tool-value": tool.id } %>
    <% end %>
  </footer>
</article>
