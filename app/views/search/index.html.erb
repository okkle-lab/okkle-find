<% content_for :title, "#{@results_title} — AI Finder" %>

<section class="results-head">
  <div class="results-toolbar">
    <h1 class="results-title"><%= @results_title %></h1>

    <%= form_with url: search_path, method: :get, class: "sort-form" do |f| %>
      <% if @query.present? %>
        <%= f.hidden_field :q, value: @query %>
      <% elsif params[:category].present? %>
        <%= f.hidden_field :category, value: params[:category] %>
      <% end %>
      <%= f.label :sort, "Sort by", class: "sort-label" %>
      <%= f.select :sort,
            options_for_select(ToolMatcher::SORTS.map { |value, label| [label, value] }, @sort),
            {},
            class: "sort-select",
            onchange: "this.form.requestSubmit()" %>
    <% end %>
  </div>

  <% chips = [] %>
  <% chips << "free for individuals" if @need.must_be_free %>
  <% chips << "private with your data" if @need.must_be_private %>
  <% chips << "able to run on your own computer" if @need.must_run_locally %>
  <% if chips.any? %>
    <p class="interpretation">Showing only tools that are
      <%= chips.map { |c| content_tag(:strong, c) }.to_sentence.html_safe %>.</p>
  <% end %>
</section>

<% if @tools.empty? %>
  <div class="empty">
    <p class="empty-head">Nothing in our catalogue matches all of that.</p>
    <p>We'd rather show you nothing than pad the list with tools that fail what you asked for.
       Try removing one requirement or searching again from the header.</p>
  </div>
<% else %>
  <% if @result.insufficient? %>
    <p class="honesty-note">Only <%= pluralize(@tools.size, "tool") %> in our catalogue genuinely fit — here they are. We won't pad the list.</p>
  <% end %>
  <% if @result.used_keyword_fallback %>
    <p class="honesty-note">We couldn't pin down exactly what you meant, so these are our closest keyword matches.</p>
  <% end %>

  <div class="card-grid">
    <%= render partial: "search/tool_card", collection: @tools, as: :tool,
          locals: { search_context: @search_context } %>
  </div>
<% end %>
