<% content_for :title, "Leaderboards — AI Finder" %>

<section class="page-head">
  <p class="hero-eyebrow">Leaderboards</p>
  <h1 class="page-title">Who's best, by task</h1>
  <p class="page-sub">Every category, ranked from our cross-judged tests. Pick a task to see the full board.</p>
</section>

<div class="lb-grid">
  <% @categories.each do |cat| %>
    <%= link_to leaderboard_path(cat[:key]), class: "lb-card" do %>
      <div class="lb-card-head">
        <span class="lb-card-name"><%= cat[:name] %></span>
        <% if cat[:leader] %>
          <%= colored_score(cat[:leader][1], css_class: "lb-card-score") %>
        <% else %>
          <span class="score-none">—</span>
        <% end %>
      </div>
      <% if cat[:leader] %>
        <p class="lb-card-leader">
          <span class="lb-rank-badge">#1</span>
          <%= cat[:leader][0].name %>
        </p>
      <% else %>
        <p class="lb-card-leader lb-card-empty">Scores rolling out</p>
      <% end %>
    <% end %>
  <% end %>
</div>
