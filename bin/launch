#!/usr/bin/env bash
# Start the AI Finder dev server: install gems if needed, prepare the
# database, open the browser, then run the Rails server. Stop with Ctrl-C.
set -euo pipefail

# This script lives in bin/, so the app root is one level up.
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

# Load a compatible Ruby and matching Bundler before any Rails commands run.
source "$APP_ROOT/bin/ruby-env"

PORT="${PORT:-3000}"
URL="http://localhost:${PORT}"

open_browser() {
  command -v open >/dev/null 2>&1 && open "$URL" || true
}

server_responding() {
  curl -s --max-time 2 -o /dev/null "$URL"
}

check_database() {
  echo "== Preparing database =="
  prepare_database
  echo "== Applying seed data =="
  bundle exec rails db:seed
  echo "== Checking seed-backed DB data =="
  bundle exec rails ai_finder:verify_seed_data
}

echo "== AI Finder =="
echo "Working in: $APP_ROOT"

echo "== Checking dependencies =="
bundle check >/dev/null 2>&1 || bundle install

legacy_schema_detected() {
  bundle exec rails runner '
    conn = ActiveRecord::Base.connection
    unless conn.table_exists?("schema_migrations")
      exit 1
    end

    current_versions = Dir[Rails.root.join("db/migrate/*.rb")].map { |path| File.basename(path).split("_", 2).first }
    recorded_versions = conn.select_values("select version from schema_migrations")
    stale_versions = recorded_versions - current_versions
    unapplied_versions = current_versions - recorded_versions

    exit(stale_versions.any? && unapplied_versions.any? ? 0 : 1)
  ' >/dev/null 2>&1
}

rebuild_development_database() {
  local database backup

  database="$(bundle exec rails runner 'print ActiveRecord::Base.connection.current_database')"
  backup="$APP_ROOT/tmp/backups/${database}_$(date +%Y%m%d_%H%M%S).sql"

  if ! command -v pg_dump >/dev/null 2>&1 || ! command -v dropdb >/dev/null 2>&1 || ! command -v createdb >/dev/null 2>&1; then
    echo "PostgreSQL command-line tools were not found, so the stale database was not rebuilt automatically." >&2
    echo "Install PostgreSQL command-line tools, then run this launcher again." >&2
    exit 1
  fi

  mkdir -p "$APP_ROOT/tmp/backups"
  pg_dump "$database" > "$backup"
  echo "== Backed up old development database to $backup =="

  dropdb --if-exists "$database"
  createdb "$database"
  bundle exec rails db:schema:load db:seed
}

prepare_database() {
  local prepare_log

  prepare_log="$(mktemp "${TMPDIR:-/tmp}/ai-finder-db-prepare.XXXXXX")"
  if bundle exec rails db:prepare >"$prepare_log" 2>&1; then
    rm -f "$prepare_log"
    return
  fi

  cat "$prepare_log"
  if grep -q "PG::DuplicateTable" "$prepare_log" && legacy_schema_detected; then
    echo "== Found an older local database schema; backing it up and rebuilding =="
    rebuild_development_database
    rm -f "$prepare_log"
    return
  fi

  rm -f "$prepare_log"
  exit 1
}

if server_responding; then
  echo "== Server already running on ${URL} =="
  check_database
  open_browser
  echo "== Database checked; using existing server =="
  exit 0
fi

check_database

# Once the server is accepting connections, open the browser.
(
  for _ in $(seq 1 60); do
    if server_responding; then break; fi
    sleep 1
  done
  open_browser
) &

echo "== Starting server on ${URL} (press Ctrl-C to stop) =="
exec bundle exec rails server -p "$PORT" -b 127.0.0.1
