#!/usr/bin/env bash
# Start the AI Finder dev server: install gems if needed, prepare the
# database, open the browser, then run the Rails server. Stop with Ctrl-C.
set -euo pipefail

# Load rbenv so the correct Ruby version is used instead of system Ruby.
export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
if command -v rbenv >/dev/null 2>&1; then eval "$(rbenv init -)"; fi

# This script lives in bin/, so the app root is one level up.
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

PORT="${PORT:-3000}"
URL="http://localhost:${PORT}"

echo "== AI Finder =="
echo "Working in: $APP_ROOT"

if ! command -v bundle >/dev/null 2>&1; then
  echo "Bundler not found — install Ruby and Bundler first (see README)." >&2
  exit 1
fi

echo "== Checking dependencies =="
bundle check >/dev/null 2>&1 || bundle install

echo "== Preparing database =="
bundle exec rails db:prepare

# Once the server is accepting connections, open the browser.
(
  for _ in $(seq 1 60); do
    if curl -s -o /dev/null "$URL"; then break; fi
    sleep 1
  done
  command -v open >/dev/null 2>&1 && open "$URL" || true
) &

echo "== Starting server on ${URL} (press Ctrl-C to stop) =="
exec bundle exec rails server -p "$PORT" -b 127.0.0.1
